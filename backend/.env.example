# ASP.NET Core hosting
ASPNETCORE_ENVIRONMENT=Development
ASPNETCORE_URLS=http://localhost:8080

# CORS (required for non-development)
Cors__AllowedOrigins__0=http://localhost:5173

# Database
Database__UseInMemory=false
ConnectionStrings__PostgreSql=Host=localhost;Port=5432;Database=taxtrack;Username=postgres;Password=postgres

# JWT
Jwt__Issuer=TaxTrack
Jwt__Audience=TaxTrack.Client
Jwt__SigningKey=ReplaceWithAtLeast32RandomCharacters
Jwt__AccessTokenMinutes=15
Jwt__RefreshTokenDays=7

# Tax policy overrides
TaxPolicy__Version=ZA-2026.01
TaxPolicy__EffectiveDate=2026-02-25
TaxPolicy__VatStandardRate=0.15
TaxPolicy__VatCompulsoryRegistrationThresholdZar=2300000
TaxPolicy__VatVoluntaryRegistrationThresholdZar=120000
TaxPolicy__Emp201DueDayOfMonth=7

# Report download signing
ReportDownloads__SigningKey=ReplaceWithAtLeast32RandomCharactersForDownloads
